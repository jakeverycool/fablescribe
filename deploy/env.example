# Fablescribe — Production env file template
#
# This file lives at /opt/fablescribe/.env on each Hetzner box.
# It is loaded by docker-compose and passed to the backend + bot containers.
#
# Per-environment values:
#   dev box:  ENV=dev,  use Supabase Dev project + Anthropic Dev key
#   prod box: ENV=prod, use Supabase Prod project + Anthropic Prod key
#
# NEVER commit this file. Copy from env.example and fill in real values.

# ── Environment label ───────────────────────────────────────────────────────
ENV=prod                            # dev | prod
# IMAGE_TAG is set automatically by deploy.sh during CI deploys.
# For manual `docker compose up`, the compose file falls back to the ENV tag
# (e.g. ENV=prod → ghcr.io/jakeverycool/fablescribe-backend:prod), which the
# build pipeline always publishes alongside the SHA tag.

# ── Caddy / domain ──────────────────────────────────────────────────────────
API_DOMAIN=api.fablescribe.io       # api-dev.fablescribe.io for dev box

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── External APIs ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=sk-ant-xxx
ELEVENLABS_API_KEY=sk_xxx
NOMIC_API_KEY=nk-xxx

# ── Bot ─────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
BOT_SECRET=                         # generate a long random string per env

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://fablescribe.io      # or https://dev.fablescribe.io for dev
