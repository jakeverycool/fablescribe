# Fablescribe Backend — Environment Variables
# Copy this file to .env and fill in real values for local dev.
# In production (Hetzner box), these are set in /opt/fablescribe/.env or
# passed in via docker-compose env_file directive.

# ── Environment label ───────────────────────────────────────────────────────
ENV=local                           # local | dev | prod

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── External APIs ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=sk-ant-xxx
ELEVENLABS_API_KEY=sk_xxx           # Starter tier+, with voices_read permission
NOMIC_API_KEY=nk-xxx

# ── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333    # Hetzner: http://qdrant:6333 (docker network)
QDRANT_API_KEY=                     # Optional — only if Qdrant has API key auth enabled

# ── Bot integration ─────────────────────────────────────────────────────────
BOT_SECRET=fablescribe-bot-secret-phase1
BOT_HTTP_URL=http://127.0.0.1:3001  # Hetzner: http://bot:3001 (docker network)

# ── CORS allowed origins ────────────────────────────────────────────────────
# Comma-separated list of origins the frontend may load from.
# Local LAN/localhost is always allowed via a built-in regex.
# dev:  https://dev.fablescribe.io
# prod: https://fablescribe.io
ALLOWED_ORIGINS=
