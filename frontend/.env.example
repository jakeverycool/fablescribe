# Fablescribe Frontend — Environment Variables
# Vite reads VITE_-prefixed vars at build time.
#
# Local dev: copy this to .env.local
# Vercel: set these in the project settings (per environment)

VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Optional. If unset, the frontend derives the backend URL from window.location.hostname:8000
# (useful for local dev so you can access via 127.0.0.1, localhost, or LAN IP without changes).
# Set this in production:
#   dev:  https://api-dev.fablescribe.io
#   prod: https://api.fablescribe.io
# VITE_BACKEND_URL=
