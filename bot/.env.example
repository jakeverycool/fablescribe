# Fablescribe Bot — Environment Variables
# Copy this file to .env and fill in real values for local dev.

# ── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# ── Backend connection ──────────────────────────────────────────────────────
# Local dev:  ws://127.0.0.1:8000/ws/bot
# Hetzner:    ws://backend:8000/ws/bot   (over docker network)
BACKEND_WS_URL=ws://127.0.0.1:8000/ws/bot

# ── Shared secret with backend (must match backend's BOT_SECRET) ───────────
BOT_SECRET=fablescribe-bot-secret-phase1

# ── Environment label ───────────────────────────────────────────────────────
ENV=local                           # local | dev | prod
